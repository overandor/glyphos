# YTL-MCP .env.example
# Copy to .env and fill in your credentials
# NEVER commit .env to Git

# YouTube OAuth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8080/oauth2callback
YOUTUBE_TOKEN_PATH=~/.ytl/token.json

# Database
DATABASE_URL=sqlite:///data/ytl_lab.db

# AI Models (optional for MVP 1)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LOCAL_MODEL_ENDPOINT=

# Media tools
FFMPEG_PATH=ffmpeg
WHISPER_MODEL=base

# Upload safety
UPLOAD_DEFAULT_PRIVACY=private

# Receipt ledger
RECEIPT_PATH=receipts/ledger.jsonl

# Lab config
LAB_NAME=YTL-MCP Research Lab
LAB_VERSION=0.1.0
